<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="0dp"
    android:layout_height="102dp"
    android:layout_columnWeight="1"
    android:layout_marginStart="8dp"
    android:layout_marginBottom="16dp"
    android:background="@drawable/bg_surface_card"
    android:gravity="center"
    android:orientation="vertical">
    <FrameLayout android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_icon_circle_red">
        <ImageView android:layout_width="20dp" android:layout_height="20dp" android:layout_gravity="center" android:src="@android:drawable/ic_menu_upload" android:tint="@color/status_danger" />
    </FrameLayout>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="PDF Report" android:textColor="@color/text_dark" android:textSize="14sp" />
</LinearLayout>

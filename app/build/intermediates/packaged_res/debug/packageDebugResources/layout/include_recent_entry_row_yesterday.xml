<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="68dp"
    android:background="@drawable/bg_row_divider_top"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="16dp">

    <View
        android:layout_width="6dp"
        android:layout_height="6dp"
        android:background="@drawable/bg_green_dot" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">
        <TextView
            android:id="@+id/recent_entry_three_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Effluent Outlet"
            android:textColor="@color/text_dark"
            android:textSize="16sp" />
        <TextView
            android:id="@+id/recent_entry_three_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Yesterday, 06:15 PM"
            android:textColor="@color/text_muted"
            android:textSize="12sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/recent_entry_three_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_table_status_synced"
        android:paddingHorizontal="12dp"
        android:paddingVertical="4dp"
        android:text="Sent"
        android:textColor="@color/brand_green"
        android:textSize="11sp" />
</LinearLayout>

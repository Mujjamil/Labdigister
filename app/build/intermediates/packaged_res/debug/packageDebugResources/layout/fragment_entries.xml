<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background"
    android:fillViewport="true"
    android:paddingBottom="110dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/brand_dark"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="20dp"
            android:paddingEnd="24dp"
            android:paddingBottom="18dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Member Entry Wizard"
                    android:textColor="@android:color/white"
                    android:textSize="22sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_reload_entry_data"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Reload"
                    android:textColor="@android:color/white"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_entry_header_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Loading assigned plants..."
                android:textColor="@color/header_label"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tv_entry_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Ready"
                android:textColor="@color/header_label"
                android:textSize="11sp"
                android:textStyle="italic" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="18dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_surface_card"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    style="@style/LabelText"
                    android:text="CURRENT MEMBER" />

                <TextView
                    android:id="@+id/tv_entry_member_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Loading..."
                    android:textColor="@color/text_dark"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/tv_entry_step_indicator"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Step 1 of 5"
                    android:textColor="@color/text_muted"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/panel_step_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_surface_card"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    style="@style/SectionTitle"
                    android:text="STEP 1 / PLANT &amp; LOCATION" />

                <TextView
                    style="@style/LabelText"
                    android:layout_marginTop="16dp"
                    android:text="PLANT" />

                <Spinner
                    android:id="@+id/spinner_plants"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp" />

                <TextView
                    style="@style/LabelText"
                    android:layout_marginTop="16dp"
                    android:text="LOCATION" />

                <Spinner
                    android:id="@+id/spinner_locations"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp" />

                <TextView
                    style="@style/LabelText"
                    android:layout_marginTop="16dp"
                    android:text="ZONE" />

                <TextView
                    android:id="@+id/tv_entry_zone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Select a location"
                    android:textColor="@color/text_muted"
                    android:textSize="14sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:gravity="end"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_step1_next"
                        style="@style/Widget.LabDigitiser.PrimaryButton"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:text="Next" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/panel_step_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_surface_card"
                android:orientation="vertical"
                android:padding="16dp"
                android:visibility="gone">

                <TextView
                    style="@style/SectionTitle"
                    android:text="STEP 2 / DATE &amp; TIME" />

                <TextView
                    style="@style/LabelText"
                    android:layout_marginTop="16dp"
                    android:text="DATE" />

                <EditText
                    android:id="@+id/edit_entry_date"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_input_small"
                    android:hint="YYYY-MM-DD"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="12dp"
                    android:textColor="@color/text_dark"
                    android:textColorHint="@color/text_hint" />

                <TextView
                    style="@style/LabelText"
                    android:layout_marginTop="16dp"
                    android:text="TIME" />

                <EditText
                    android:id="@+id/edit_entry_time"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_input_small"
                    android:hint="HH:MM"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="12dp"
                    android:textColor="@color/text_dark"
                    android:textColorHint="@color/text_hint" />

                <TextView
                    style="@style/LabelText"
                    android:layout_marginTop="16dp"
                    android:text="SHIFT" />

                <TextView
                    android:id="@+id/tv_entry_shift"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Morning"
                    android:textColor="@color/text_dark"
                    android:textSize="14sp" />

                <TextView
                    style="@style/LabelText"
                    android:layout_marginTop="16dp"
                    android:text="NOTES (OPTIONAL)" />

                <EditText
                    android:id="@+id/edit_entry_notes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_input_small"
                    android:gravity="top"
                    android:hint="Any observations..."
                    android:minLines="3"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="12dp"
                    android:textColor="@color/text_dark"
                    android:textColorHint="@color/text_hint" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_step2_back"
                        style="@style/Widget.LabDigitiser.OutlineButton"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:text="Back" />

                    <Space
                        android:layout_width="12dp"
                        android:layout_height="1dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_step2_next"
                        style="@style/Widget.LabDigitiser.PrimaryButton"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:text="Next" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/panel_step_3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_surface_card"
                android:orientation="vertical"
                android:padding="16dp"
                android:visibility="gone">

                <TextView
                    style="@style/SectionTitle"
                    android:text="STEP 3 / PARAMETERS" />

                <TextView
                    android:id="@+id/tv_entry_parameter_empty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Loading parameters..."
                    android:textColor="@color/text_muted"
                    android:textSize="14sp" />

                <LinearLayout
                    android:id="@+id/container_parameter_fields"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_step3_back"
                        style="@style/Widget.LabDigitiser.OutlineButton"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:text="Back" />

                    <Space
                        android:layout_width="12dp"
                        android:layout_height="1dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_step3_next"
                        style="@style/Widget.LabDigitiser.PrimaryButton"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:text="Next" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/panel_step_4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_surface_card"
                android:orientation="vertical"
                android:padding="16dp"
                android:visibility="gone">

                <TextView
                    style="@style/SectionTitle"
                    android:text="STEP 4 / EQUIPMENT" />

                <TextView
                    style="@style/LabelText"
                    android:layout_marginTop="16dp"
                    android:text="SELECT EQUIPMENT" />

                <Spinner
                    android:id="@+id/spinner_equipment"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp" />

                <TextView
                    style="@style/LabelText"
                    android:layout_marginTop="16dp"
                    android:text="CONDITION" />

                <Spinner
                    android:id="@+id/spinner_equipment_condition"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_step4_back"
                        style="@style/Widget.LabDigitiser.OutlineButton"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:text="Back" />

                    <Space
                        android:layout_width="12dp"
                        android:layout_height="1dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_step4_next"
                        style="@style/Widget.LabDigitiser.PrimaryButton"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:text="Next" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/panel_step_5"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_surface_card"
                android:orientation="vertical"
                android:padding="16dp"
                android:visibility="gone">

                <TextView
                    style="@style/SectionTitle"
                    android:text="STEP 5 / REVIEW &amp; SUBMIT" />

                <TextView
                    style="@style/LabelText"
                    android:layout_marginTop="16dp"
                    android:text="SUMMARY" />

                <TextView
                    android:id="@+id/tv_entry_summary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Review your entry before submitting."
                    android:textColor="@color/text_dark"
                    android:textSize="14sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_step5_back"
                        style="@style/Widget.LabDigitiser.OutlineButton"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:text="Back" />

                    <Space
                        android:layout_width="12dp"
                        android:layout_height="1dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_submit_entry"
                        style="@style/Widget.LabDigitiser.PrimaryButton"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:text="Submit Entry" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>

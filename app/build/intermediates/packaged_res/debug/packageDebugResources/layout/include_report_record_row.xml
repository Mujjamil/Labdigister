<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <TextView
            android:id="@+id/tv_row_date"
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:textColor="@color/text_dark"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tv_row_location"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/text_dark"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tv_row_ph"
            android:layout_width="46dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="@color/text_dark"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_row_tds"
            android:layout_width="54dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="@color/text_dark"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tv_row_status"
            android:layout_width="72dp"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_table_status_synced"
            android:gravity="center"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:text="SYNCED"
            android:textColor="@color/brand_green"
            android:textSize="10sp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border_soft" />
</LinearLayout>

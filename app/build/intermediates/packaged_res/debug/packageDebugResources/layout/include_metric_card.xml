<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="0dp"
    android:layout_height="154dp"
    android:layout_columnWeight="1"
    android:layout_marginEnd="10dp"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_surface_card"
    android:orientation="vertical"
    android:paddingStart="22dp"
    android:paddingTop="26dp"
    android:paddingEnd="22dp"
    android:paddingBottom="18dp">

    <TextView
        android:id="@+id/metric_one_label"
        style="@style/MetricLabel"
        android:text="Records" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:gravity="bottom"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/metric_one_value"
            style="@style/MetricValue"
            android:text="0" />

        <TextView
            android:id="@+id/metric_one_unit"
            style="@style/MetricUnit"
            android:text="" />
    </LinearLayout>
</LinearLayout>

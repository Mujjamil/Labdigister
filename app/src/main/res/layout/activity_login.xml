<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/login_screen_base">

    <View
        android:id="@+id/top_section"
        android:layout_width="0dp"
        android:layout_height="250dp"
        android:background="@color/login_header_dark"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/top_watermark"
        android:layout_width="200dp"
        android:layout_height="250dp"
        android:adjustViewBounds="true"
        android:alpha="0.92"
        android:scaleType="fitXY"
        android:src="@drawable/bg_login_watermark"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="64dp"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <FrameLayout
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/bg_logo_badge">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="30dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_lab_drop"
                app:tint="@color/login_brand_mint" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="@font/plusjakartasans_extrabold"
            android:textStyle="normal"
            android:text="@string/app_name"
            android:textColor="@color/login_brand_mint"
            android:textSize="30sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:fontFamily="@font/plus_jakarta_sans"

            android:letterSpacing="0.04"
            android:text="@string/water_quality_monitor"
            android:textAllCaps="true"
            android:textColor="@color/login_brand_mint_muted"
            android:textSize="12sp" />
    </LinearLayout>

    <View
        android:id="@+id/login_bottom_gradient"
        android:layout_width="0dp"
        android:layout_height="4dp"
        android:background="@drawable/bg_login_bottom_gradient"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/login_scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingTop="225dp"
        app:layout_constraintBottom_toTopOf="@id/footer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <View
                android:layout_width="match_parent"
                android:layout_height="420dp"
                android:layout_gravity="top|center_horizontal"
                android:layout_marginStart="18dp"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="18dp"
                android:background="@drawable/bg_login_card_glow" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="0dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="20dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="28dp"
                app:cardElevation="18dp"
                app:strokeColor="@color/login_card_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="33dp"
                    android:paddingTop="33dp"
                    android:paddingEnd="33dp"
                    android:paddingBottom="49dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/plusjakartasans_extrabold"
                        android:text="@string/welcome_back"
                        android:textColor="@color/login_text_primary"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:text="@string/sign_in_prompt"
                        android:textColor="@color/login_text_secondary"
                        android:textSize="14sp" />

                    <TextView
                        style="@style/LoginFieldLabel"
                        android:layout_marginTop="30dp"
                        android:fontFamily="@font/plusjakartasans_extrabold"
                        android:text="@string/username"
                        android:textStyle="bold" />

                    <LinearLayout style="@style/LoginInputShell">

                        <ImageView
                            style="@style/LoginInputIcon"
                            android:layout_height="wrap_content"
                            android:src="@drawable/user" />

                        <EditText
                            android:id="@+id/login_email"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@null"
                            android:fontFamily="@font/plus_jakarta_sans"
                            android:hint="@string/username_hint"
                            android:inputType="textEmailAddress"
                            android:padding="0dp"
                            android:textColor="@color/login_text_primary"
                            android:textColorHint="@color/login_hint" />
                    </LinearLayout>

                    <TextView
                        style="@style/LoginFieldLabel"
                        android:layout_marginTop="24dp"
                        android:fontFamily="@font/plusjakartasans_extrabold"
                        android:text="@string/password"

                        android:textStyle="bold" />

                    <LinearLayout style="@style/LoginInputShell">

                        <ImageView
                            style="@style/LoginInputIcon"
                            android:src="@drawable/img" />

                        <EditText
                            android:id="@+id/login_password"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="2dp"
                            android:layout_weight="1"
                            android:background="@null"
                            android:fontFamily="@font/plus_jakarta_sans"
                            android:hint="@string/password"
                            android:inputType="textPassword"
                            android:padding="0dp"
                            android:textColor="@color/login_text_primary"
                            android:textColorHint="@color/login_hint" />

                        <ImageView
                            style="@style/LoginInputIcon"
                            android:layout_marginStart="8dp"
                            android:src="@drawable/ic_eye_outline" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/login_button"
                        style="@style/Widget.LabDigitiser.LoginButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="34dp"
                        android:fontFamily="@font/plusjakartasans_extrabold"
                        android:text="@string/login" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </FrameLayout>
    </androidx.core.widget.NestedScrollView>

    <TextView
        android:id="@+id/footer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="28dp"
        android:fontFamily="@font/plus_jakarta_sans"
        android:text="LAB DIGITISER V1.0 • SECURE LOGIN"
        android:textColor="@color/login_footer_text"
        android:letterSpacing="0.1"
        android:textSize="10sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.LabDigitiser" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/brand_green</item>
        <item name="colorPrimaryVariant">@color/brand_dark</item>
        <item name="colorSecondary">@color/brand_green</item>
        <item name="android:statusBarColor" tools:targetApi="l">@color/brand_dark</item>
        <item name="android:navigationBarColor">@android:color/white</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowBackground">@color/screen_background</item>
    </style>

    <style name="Widget.LabDigitiser.PrimaryButton" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/brand_green</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="iconGravity">textEnd</item>
    </style>

    <style name="Widget.LabDigitiser.LoginButton" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/brand_green</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textSize">16sp</item>
        <item name="icon">@drawable/ic_arrow_right_small</item>
        <item name="iconGravity">textEnd</item>
        <item name="iconPadding">8dp</item>
        <item name="iconTint">@android:color/white</item>
        <item name="elevation">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <style name="Widget.LabDigitiser.OutlineButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/brand_green</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/brand_green</item>
    </style>

    <style name="Widget.LabDigitiser.ExportButton" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/brand_green_soft</item>
        <item name="cornerRadius">10dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/brand_dark</item>
        <item name="icon">@android:drawable/ic_menu_upload</item>
        <item name="iconGravity">textEnd</item>
        <item name="iconTint">@color/brand_dark</item>
    </style>

    <style name="Widget.LabDigitiser.ChoiceChip" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="chipBackgroundColor">@color/surface_alt</item>
        <item name="chipCornerRadius">18dp</item>
        <item name="chipStrokeColor">@color/border_soft</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="android:textColor">@color/text_muted</item>
    </style>

    <style name="Widget.LabDigitiser.ChoiceChipActive" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="chipBackgroundColor">@color/brand_green_soft</item>
        <item name="chipCornerRadius">18dp</item>
        <item name="chipStrokeColor">@color/brand_green</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="android:textColor">@color/brand_green</item>
    </style>

    <style name="LabelText">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/brand_green</item>
        <item name="android:textSize">11sp</item>
    </style>

    <style name="LoginFieldLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textColor">@color/brand_green</item>
        <item name="android:textSize">12sp</item>
        <item name="android:letterSpacing">0.04</item>
    </style>

    <style name="LoginInputShell">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">50dp</item>
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:background">@drawable/bg_login_input_exact</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
    </style>

    <style name="LoginInputIcon">
        <item name="android:layout_width">18dp</item>
        <item name="android:layout_height">18dp</item>
        <item name="android:tint">@color/login_hint</item>
    </style>

    <style name="LoginRoleChip">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingStart">17dp</item>
        <item name="android:paddingEnd">17dp</item>
        <item name="android:background">@drawable/bg_login_role_chip</item>
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
        <item name="android:textColor">@color/login_text_secondary</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="LoginRoleChipActive" parent="LoginRoleChip">
        <item name="android:background">@drawable/bg_login_role_chip_active</item>
        <item name="android:textColor">@color/brand_green</item>
    </style>

    <style name="SectionTitle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textColor">@color/text_muted</item>
        <item name="android:textSize">12sp</item>
        <item name="android:letterSpacing">0.1</item>
    </style>

    <style name="MetricLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textColor">@color/text_muted</item>
        <item name="android:textSize">12sp</item>
        <item name="android:letterSpacing">0.08</item>
    </style>

    <style name="MetricValue">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/text_dark</item>
        <item name="android:textSize">32sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="MetricUnit">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/text_muted</item>
        <item name="android:textSize">11sp</item>
        <item name="android:layout_marginStart">6dp</item>
        <item name="android:layout_marginBottom">4dp</item>
    </style>

    <style name="ReportValue">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/brand_green</item>
        <item name="android:textSize">38sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:layout_marginTop">8dp</item>
    </style>

    <style name="InputShell">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">50dp</item>
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:background">@drawable/bg_input</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:paddingHorizontal">16dp</item>
    </style>

    <style name="InputShellSmall" parent="InputShell">
        <item name="android:layout_height">48dp</item>
    </style>

    <style name="InputIcon">
        <item name="android:layout_width">16dp</item>
        <item name="android:layout_height">16dp</item>
        <item name="android:tint">@color/text_muted</item>
    </style>

    <style name="ChoicePill">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">28dp</item>
        <item name="android:layout_margin">6dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:background">@drawable/bg_chip_inactive</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:paddingHorizontal">14dp</item>
        <item name="android:textColor">@color/brand_green</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="ChoicePillActive" parent="ChoicePill">
        <item name="android:background">@drawable/bg_chip_active</item>
        <item name="android:textColor">@android:color/white</item>
    </style>

    <style name="ValueBox">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:background">@drawable/bg_input_small</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:paddingHorizontal">10dp</item>
    </style>

    <style name="UnitBox" parent="ValueBox">
        <item name="android:gravity">center_vertical</item>
        <item name="android:orientation">horizontal</item>
    </style>

    <style name="FilterChip">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">36dp</item>
        <item name="android:layout_marginEnd">12dp</item>
        <item name="android:background">@drawable/bg_chip_inactive</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingHorizontal">16dp</item>
        <item name="android:textColor">@color/text_muted</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="FilterChipActive" parent="FilterChip">
        <item name="android:background">@drawable/bg_chip_active</item>
        <item name="android:textColor">@android:color/white</item>
    </style>

    <style name="TableHeaderCell">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/text_muted</item>
        <item name="android:textSize">10sp</item>
    </style>

    <style name="TableHeaderCellCenter" parent="TableHeaderCell">
        <item name="android:gravity">center</item>
    </style>

    <style name="TableCell">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/text_dark</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="TableCellCenter" parent="TableCell">
        <item name="android:gravity">center</item>
    </style>

    <style name="TableStatusCell">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/bg_table_status_synced</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingVertical">4dp</item>
        <item name="android:textColor">@color/brand_green</item>
        <item name="android:textSize">10sp</item>
    </style>

    <style name="TextAppearance.LabDigitiser.BottomNav" parent="TextAppearance.AppCompat.Caption">
        <item name="android:textSize">11sp</item>
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">0</item>
    </style>
</resources>
